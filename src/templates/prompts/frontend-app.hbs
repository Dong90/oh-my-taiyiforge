// ── State ──
let isLoading = false;

// ── DOM references (lazy init) ──
const $ = (sel) => document.querySelector(sel);
const $$ = (sel) => document.querySelectorAll(sel);

// ── API Client ──
async function apiPost(endpoint, body) {
    const response = await fetch(API_BASE_URL + endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
    });
    if (!response.ok) {
        const err = await response.json().catch(() => ({ message: `HTTP ${response.status}` }));
        throw new Error(err.message || `Request failed: ${response.status}`);
    }
    return response.json();
}

async function apiPostStream(endpoint, body, onChunk, onDone, onError) {
    try {
        const response = await fetch(API_BASE_URL + endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...body, stream: true }),
        });
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        
        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';
        
        while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            buffer += decoder.decode(value, { stream: true });
            
            const lines = buffer.split('\n');
            buffer = lines.pop() || '';
            
            for (const line of lines) {
                if (line.startsWith('data: ')) {
                    const data = line.slice(6);
                    if (data === '[DONE]') { onDone?.(); return; }
                    if (data === '[ERROR]') { onError?.(new Error('Stream error')); return; }
                    try {
                        const parsed = JSON.parse(data);
                        if (parsed.error) { onError?.(new Error(parsed.message)); return; }
                        onChunk?.(parsed.chunk || data);
                    } catch { onChunk?.(data); }
                }
            }
        }
        onDone?.();
    } catch (err) {
        onError?.(err);
    }
}

// ── UI helpers ──
function setLoading(state) {
    isLoading = state;
    const btns = $$('button[type="submit"], .btn-primary');
    btns.forEach(b => { b.disabled = state; b.textContent = state ? '处理中...' : b.dataset.originalText || b.textContent; });
    if (!state) btns.forEach(b => { b.dataset.originalText = b.textContent; });
}

function showError(message) {
    const toast = document.createElement('div');
    toast.className = 'toast toast-error';
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
}

function showSuccess(message) {
    const toast = document.createElement('div');
    toast.className = 'toast toast-success';
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}

function renderMarkdown(text, container) {
    if (typeof marked !== 'undefined') {
        marked.setOptions({ breaks: true, gfm: true });
        container.innerHTML = marked.parse(text);
    } else {
        container.textContent = text;
    }
}

// ── Health check ──
async function checkBackendHealth() {
    try {
        const res = await fetch(API_BASE_URL + '/health');
        if (res.ok) {
            const status = $('#backend-status');
            if (status) { status.textContent = '✅ Connected'; status.className = 'status-ok'; }
        }
    } catch {
        const status = $('#backend-status');
        if (status) { status.textContent = '❌ Disconnected'; status.className = 'status-error'; }
    }
}

// ── Init ──
document.addEventListener('DOMContentLoaded', () => {
    checkBackendHealth();
    setInterval(checkBackendHealth, 30000);
});
