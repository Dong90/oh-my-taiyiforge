"""Error handler middleware — generated by TaiyiForge DEV phase (pattern: {{pattern}})"""

import json
from starlette.middleware.base import BaseHTTPMiddleware
from starlette.requests import Request
from starlette.responses import JSONResponse
from ..core.logger import get_logger
from ..core.exceptions import AppException

logger = get_logger(__name__)


class ErrorHandlerMiddleware(BaseHTTPMiddleware):
    """Catch-all error handler that returns JSON error responses.
    
    Catches unhandled exceptions and converts them to structured JSON.
    Does NOT catch AppException (handled by global exception_handler).
    """
    
    async def dispatch(self, request: Request, call_next):
        try:
            return await call_next(request)
        except AppException:
            # Let the global exception handler deal with known exceptions
            raise
        except Exception as e:
            logger.error(
                "Unhandled error in middleware",
                method=request.method,
                path=request.url.path,
                error_type=type(e).__name__,
                error=str(e),
                exc_info=e,
            )
            return JSONResponse(
                status_code=500,
                content={
                    "error": True,
                    "message": "Internal server error",
                    "error_code": "INTERNAL_ERROR",
                    "method": request.method,
                    "path": request.url.path,
                },
            )


def setup_error_handler_middleware(app):
    """Register error handler middleware on the FastAPI app."""
    app.add_middleware(ErrorHandlerMiddleware)
    logger.info("Error handler middleware registered")
