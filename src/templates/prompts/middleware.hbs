"""{{class_name}} — generated by TaiyiForge DEV phase (pattern: {{pattern}})"""

import time
import json
import uuid
from contextvars import ContextVar
from starlette.middleware.base import BaseHTTPMiddleware
from starlette.requests import Request
from starlette.responses import Response
from ..core.logger import get_logger

logger = get_logger(__name__)

# Context-local request ID for async-safe tracing
_request_id_var: ContextVar[str] = ContextVar("request_id", default="")
_request_start_time_var: ContextVar[float] = ContextVar("request_start_time", default=0.0)


def get_request_id() -> str:
    """Get current request ID from context."""
    return _request_id_var.get()


class {{class_name}}(BaseHTTPMiddleware):
    """Request logging middleware with JSON structured output.
    
    Injects request_id via contextvars for async-safe propagation.
    Logs: request start, completion (duration + status), and errors.
    """
    
    async def dispatch(self, request: Request, call_next) -> Response:
        # Generate unique request ID
        request_id = str(uuid.uuid4())
        _request_id_var.set(request_id)
        _request_start_time_var.set(time.time())
        
        # Attach to request state for downstream access
        request.state.request_id = request_id
        
        # Log incoming request
        logger.info(
            "Request started",
            request_id=request_id,
            method=request.method,
            path=request.url.path,
            query=str(request.url.query) if request.url.query else None,
            client_ip=request.client.host if request.client else None
        )
        
        # Process request
        try:
            response = await call_next(request)
            
            duration_ms = (time.time() - _request_start_time_var.get()) * 1000
            _request_id_var.set(request_id)  # Restore after potential context loss
            
            logger.info(
                "Request completed",
                request_id=request_id,
                status_code=response.status_code,
                duration_ms=round(duration_ms, 2),
                method=request.method,
                path=request.url.path
            )
            
            # Add response headers
            response.headers["X-Request-ID"] = request_id
            response.headers["X-Response-Time"] = str(round(duration_ms)) + "ms"
            
            return response
            
        except Exception as e:
            duration_ms = (time.time() - _request_start_time_var.get()) * 1000
            
            logger.error(
                "Request failed",
                request_id=request_id,
                error_type=type(e).__name__,
                error=str(e),
                duration_ms=round(duration_ms, 2),
                method=request.method,
                path=request.url.path,
                exc_info=e
            )
            raise
