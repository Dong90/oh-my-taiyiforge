"""Health check endpoints — generated by TaiyiForge DEV phase (pattern: {{pattern}})"""

from fastapi import APIRouter, Depends
from ..core.logger import get_logger
{{#each import_deps}}from {{from}} import {{name}}
{{/each}}
import time

logger = get_logger(__name__)

router = APIRouter(tags=["health"])

# Startup timestamp for uptime calculation
_startup_time = time.time()


@router.get("/health")
async def health():
    """Basic health check — service is running."""
    return {
        "status": "healthy",
        "timestamp": time.time(),
        "uptime_seconds": round(time.time() - _startup_time, 2),
    }


@router.get("/ready")
async def ready():
    """Readiness check — service + all dependencies are ready.
    
    Returns 200 if all required services/dependencies are available.
    Returns 503 if any dependency is unavailable.
    """
    from fastapi.responses import JSONResponse
    
    checks = {}
    all_ok = True
    
    {{#each depends_on}}
    try:
        {{#if type}}{{#if (eq type "http")}}
        import httpx
        async with httpx.AsyncClient(timeout=5.0) as client:
            resp = await client.get("{{endpoint}}")
        checks["{{name}}"] = "ok" if resp.status_code < 500 else "degraded"
        if resp.status_code >= 500: all_ok = False
        {{else if (eq type "import")}}
        import {{module}}
        checks["{{name}}"] = "ok"
        {{/if}}{{else}}pass  # {{name}}: no check defined
        checks["{{name}}"] = "unknown"{{/if}}
    except Exception as e:
        checks["{{name}}"] = "unavailable: " + str(e)
        all_ok = False
    {{/each}}
    
    {{#unless depends_on}}
    # No external dependencies — always ready
    checks["app"] = "ok"
    {{/unless}}
    
    status_code = 200 if all_ok else 503
    return JSONResponse(
        content={
            "status": "ready" if all_ok else "not_ready",
            "checks": checks,
            "uptime_seconds": round(time.time() - _startup_time, 2),
        },
        status_code=status_code,
    )


@router.get("/live")
async def live():
    """Liveness check — service is alive (no dependency check).
    
    Returns 200 as long as the process is running.
    Kubernetes uses this for pod liveness probe.
    """
    return {
        "status": "alive",
        "timestamp": time.time(),
    }
