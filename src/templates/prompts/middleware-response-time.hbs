"""Response time tracking middleware — generated by TaiyiForge DEV phase (pattern: {{pattern}})"""

import time
from starlette.middleware.base import BaseHTTPMiddleware
from starlette.requests import Request
from ..core.logger import get_logger

logger = get_logger(__name__)


class ResponseTimeMiddleware(BaseHTTPMiddleware):
    """Middleware that logs request duration and warns on slow requests.
    
    Add AFTER logging middleware (so request_id is available).
    """
    
    def __init__(self, app, slow_request_threshold_ms: float = 1000.0):
        super().__init__(app)
        self.slow_threshold = slow_request_threshold_ms
    
    async def dispatch(self, request: Request, call_next):
        start = time.time()
        response = await call_next(request)
        duration_ms = (time.time() - start) * 1000
        
        if duration_ms > self.slow_threshold:
            logger.warning(
                "Slow request detected",
                method=request.method,
                path=request.url.path,
                duration_ms=round(duration_ms, 2),
                threshold_ms=self.slow_threshold,
                status_code=response.status_code,
            )
        
        response.headers["X-Response-Time"] = f"{round(duration_ms)}ms"
        return response


def setup_response_time_middleware(app, slow_request_threshold_ms: float = 1000.0):
    """Register response time middleware on the FastAPI app."""
    app.add_middleware(ResponseTimeMiddleware, slow_request_threshold_ms=slow_request_threshold_ms)
    logger.info("Response time middleware registered", threshold_ms=slow_request_threshold_ms)
