from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
{{#each controller_imports}}
from {{from}} import {{name}}
{{/each}}
{{#each middleware_setup_imports}}
from {{from}} import {{name}}
{{/each}}
from .core.logger import get_logger
from .core.exceptions import AppException
from .config.settings import settings
{{#if has_exception_handler}}from .core.exception_handler import setup_exception_handlers{{/if}}

logger = get_logger(__name__)

app = FastAPI(
    title=settings.app_name,
    description="{{app_description}}",
    version=settings.app_version,
)

# ── CORS ──
app.add_middleware(
    CORSMiddleware,
    allow_origins=settings.get_cors_origins() if hasattr(settings, "get_cors_origins") else settings.cors_origins,
    allow_credentials=True,
    allow_methods=["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    allow_headers=["*"],
)

# ── Exception Handlers ──
{{#if has_exception_handler}}
setup_exception_handlers(app)
{{/if}}

# ── Middleware (order matters: logging → timing → error) ──
{{#each middleware_setups}}
{{function}}(app{{#each args}}, {{name}}={{value}}{{/each}})
{{/each}}

# ── Routers ──
{{#each router_registrations}}
app.include_router({{name}}{{#if prefix}}, prefix="{{prefix}}"{{/if}})
{{/each}}

# ── Root ──
@app.get("/")
async def root():
    """API information endpoint"""
    return {
        "app": settings.app_name,
        "version": settings.app_version,
        "endpoints": {
            {{#each router_registrations}}
            "{{tag}}": "{{prefix}}",
            {{/each}}
            "health": "/health",
        }
    }


@app.exception_handler(AppException)
async def app_exception_handler(request, exc: AppException):
    """Global handler for all application exceptions."""
    from fastapi.responses import JSONResponse
    logger.error(
        "Unhandled application exception",
        error_code=exc.error_code,
        error=str(exc),
        path=request.url.path,
    )
    return JSONResponse(
        status_code=exc.status_code,
        content=exc.to_dict(),
    )


logger.info(
    "Application started",
    app_name=settings.app_name,
    version=settings.app_version,
    environment=settings.environment if hasattr(settings, "environment") else "production",
    debug=settings.debug,
)
