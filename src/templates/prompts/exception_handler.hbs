"""Global exception handlers — generated by TaiyiForge DEV phase.

Sets up FastAPI exception handlers for all AppException subclasses.
"""

from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse
from .logger import get_logger
from .exceptions import AppException, ValidationException, ConfigurationException, AdapterException, ServiceException, NotFoundException

logger = get_logger(__name__)


async def _validation_exception_handler(request: Request, exc: ValidationException):
    """Handle validation errors (400)."""
    logger.warning(
        "Validation error",
        error_code=exc.error_code,
        error=exc.message,
        path=request.url.path,
    )
    return JSONResponse(status_code=400, content=exc.to_dict())


async def _not_found_handler(request: Request, exc: NotFoundException):
    """Handle not found errors (404)."""
    logger.info(
        "Resource not found",
        error_code=exc.error_code,
        path=request.url.path,
    )
    return JSONResponse(status_code=404, content=exc.to_dict())


async def _adapter_exception_handler(request: Request, exc: AdapterException):
    """Handle external service errors (502)."""
    logger.error(
        "External service failure",
        error_code=exc.error_code,
        error=exc.message,
        path=request.url.path,
    )
    return JSONResponse(status_code=502, content=exc.to_dict())


async def _app_exception_handler(request: Request, exc: AppException):
    """Handle all other application errors."""
    logger.error(
        "Unhandled application error",
        error_code=exc.error_code,
        error=exc.message,
        path=request.url.path,
    )
    return JSONResponse(status_code=exc.status_code, content=exc.to_dict())


async def _unhandled_exception_handler(request: Request, exc: Exception):
    """Catch-all for unhandled exceptions (500)."""
    logger.error(
        "Unhandled exception",
        error_type=type(exc).__name__,
        error=str(exc),
        path=request.url.path,
        exc_info=exc,
    )
    return JSONResponse(
        status_code=500,
        content={
            "error": True,
            "message": "Internal server error",
            "error_code": "INTERNAL_ERROR",
        },
    )


def setup_exception_handlers(app: FastAPI):
    """Register all exception handlers on the FastAPI app."""
    app.add_exception_handler(ValidationException, _validation_exception_handler)
    app.add_exception_handler(NotFoundException, _not_found_handler)
    app.add_exception_handler(AdapterException, _adapter_exception_handler)
    app.add_exception_handler(AppException, _app_exception_handler)
    app.add_exception_handler(Exception, _unhandled_exception_handler)
    logger.info("Exception handlers registered")
