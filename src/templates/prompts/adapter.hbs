from typing import AsyncIterator
from openai import AsyncOpenAI
import httpx
{{#if extends}}from .base import {{extends}}
{{/if}}from ..core.logger import get_logger
from ..core.exceptions import AdapterException, ConfigurationException
from ..config.settings import settings

logger = get_logger(__name__)


class {{class_name}}({{extends}}):
    """OpenAI-compatible API adapter.
    
    Implements {{extends}} interface with defensive error handling.
    Configuration priority: constructor params > settings.py defaults.
    """
    
    def __init__(self, api_key: str = None, base_url: str = None, model: str = None):
        """Initialize adapter with configurable parameters.
        
        Args:
            api_key: API key (falls back to settings.openai_api_key)
            base_url: Custom endpoint URL (falls back to settings.openai_api_base_url)
            model: Model name (falls back to settings.openai_model)
            
        Raises:
            ConfigurationException: If API key cannot be resolved
        """
        # Resolve API key with safety guard
        if api_key and api_key.startswith("test-"):
            logger.error("CRITICAL: Test API key passed to adapter, forcing settings default")
            api_key = None
        
        self.api_key = api_key or settings.openai_api_key
        if not self.api_key:
            raise ConfigurationException(
                "OpenAI API key is required. Configure via frontend settings, env var, or settings.py.",
                error_code="MISSING_API_KEY"
            )
        
        self.base_url = base_url or settings.openai_api_base_url
        if self.base_url and not (self.base_url.startswith("http://") or self.base_url.startswith("https://")):
            raise ConfigurationException(
                "Invalid API base URL format. Must start with http:// or https://",
                error_code="INVALID_BASE_URL",
                status_code=400
            )
        
        self.model = model or settings.openai_model
        
        # Build client with timeout and retry config
        client_kwargs = {
            "api_key": self.api_key,
            "timeout": settings.openai_timeout,
            "max_retries": settings.openai_max_retries
        }
        if self.base_url:
            client_kwargs["base_url"] = self.base_url
        
        try:
            http_client = httpx.AsyncClient(
                timeout=httpx.Timeout(settings.openai_timeout, connect=10.0),
                follow_redirects=True
            )
            client_kwargs["http_client"] = http_client
        except Exception as e:
            logger.warning("Failed to create custom http_client, using default", error=str(e))
        
        self.client = AsyncOpenAI(**client_kwargs)
        logger.info(
            "Adapter initialized",
            model=self.model,
            api_key_source="param" if api_key and not api_key.startswith("test-") else "settings",
            base_url=self.base_url or "default"
        )
    
    async def complete(self, prompt: str, system_prompt: str = "") -> str:
        """One-shot text generation.
        
        Returns:
            str: Complete response text
            
        Raises:
            AdapterException: On API error, empty response, or empty content
        """
        messages = []
        if system_prompt:
            messages.append({"role": "system", "content": system_prompt})
        messages.append({"role": "user", "content": prompt})
        
        try:
            response = await self.client.chat.completions.create(
                model=self.model,
                messages=messages
            )
        except Exception as e:
            logger.error("API call failed", error_type=type(e).__name__, error=str(e), exc_info=e)
            raise AdapterException(
                "OpenAI API call failed: " + str(e),
                error_code="API_CALL_ERROR"
            ) from e
        
        if not response.choices or len(response.choices) == 0:
            raise AdapterException("OpenAI API returned empty response", error_code="EMPTY_RESPONSE")
        
        message = response.choices[0].message
        if not message or not message.content:
            raise AdapterException("OpenAI API returned empty content", error_code="EMPTY_CONTENT")
        
        return message.content
    
    async def stream_complete(self, prompt: str, system_prompt: str = "") -> AsyncIterator[str]:
        """Streaming text generation with chunk-level error handling.
        
        Yields:
            str: Text chunks from the streaming response
        """
        messages = []
        if system_prompt:
            messages.append({"role": "system", "content": system_prompt})
        messages.append({"role": "user", "content": prompt})
        
        try:
            stream = await self.client.chat.completions.create(
                model=self.model,
                messages=messages,
                stream=True
            )
            async for chunk in stream:
                try:
                    if chunk.choices and len(chunk.choices) > 0:
                        delta = chunk.choices[0].delta
                        if delta and delta.content:
                            yield delta.content
                except (IndexError, AttributeError) as e:
                    logger.warning("Invalid chunk format", error_type=type(e).__name__)
                    continue
        except Exception as e:
            logger.error("Stream API call failed", error_type=type(e).__name__, error=str(e), exc_info=e)
            raise AdapterException(
                "OpenAI API stream call failed: " + str(e),
                error_code="STREAM_API_ERROR"
            ) from e
