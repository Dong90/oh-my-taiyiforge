/* Metrics Dashboard — generated by TaiyiForge auto-plan */
.metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
.metric-card { background: var(--color-bg, #f8f9fa); border-radius: var(--radius, 8px); padding: 1.5rem; text-align: center; }
.metric-value { font-size: 2rem; font-weight: 700; color: var(--color-primary, #2563eb); }
.metric-label { font-size: .8125rem; color: var(--color-text-secondary, #64748b); margin-top: .25rem; }
.chart-container { min-height: 150px; }
.bar-row { display: flex; align-items: center; gap: .5rem; padding: .375rem 0; }
.bar-label { font-size: .8125rem; min-width: 140px; color: var(--color-text-secondary, #64748b); }
.bar { height: 22px; background: var(--color-primary, #2563eb); border-radius: 4px; min-width: 2px; transition: width .3s; }
.bar-value { font-size: .8125rem; font-weight: 600; min-width: 50px; text-align: right; }
.error-log { max-height: 250px; overflow-y: auto; font-family: var(--font-mono, monospace); font-size: .8125rem; }
.error-entry { padding: .25rem 0; border-bottom: 1px solid var(--color-border, #e2e8f0); }
.error-time { color: var(--color-text-secondary, #64748b); margin-right: .5rem; }
.error-type { color: var(--color-error, #ef4444); font-weight: 600; margin-right: .5rem; }
table { width: 100%; border-collapse: collapse; }
th, td { border: 1px solid var(--color-border, #e2e8f0); padding: .5rem .75rem; text-align: left; }
th { background: var(--color-bg, #f8f9fa); font-weight: 600; }
