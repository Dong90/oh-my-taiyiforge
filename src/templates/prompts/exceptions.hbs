"""Custom exception hierarchy — generated by TaiyiForge DEV phase"""

from typing import Optional


class AppException(Exception):
    """Base application exception with error code support.
    
    All custom exceptions inherit from this class to enable
    unified error handling in middleware and controllers.
    """
    
    def __init__(self, message: str, error_code: str = "UNKNOWN_ERROR", status_code: int = 500):
        self.message = message
        self.error_code = error_code
        self.status_code = status_code
        super().__init__(self.message)
    
    def to_dict(self) -> dict:
        return {
            "error": True,
            "message": self.message,
            "error_code": self.error_code,
            "status_code": self.status_code,
        }


class ValidationException(AppException):
    """Input validation failure (400)."""
    
    def __init__(self, message: str, error_code: str = "VALIDATION_ERROR"):
        super().__init__(message, error_code=error_code, status_code=400)


class ConfigurationException(AppException):
    """Configuration error — missing/invalid config (500)."""
    
    def __init__(self, message: str, error_code: str = "CONFIG_ERROR", status_code: int = 500):
        super().__init__(message, error_code=error_code, status_code=status_code)


class AdapterException(AppException):
    """External service/API call failure (502)."""
    
    def __init__(self, message: str, error_code: str = "ADAPTER_ERROR"):
        super().__init__(message, error_code=error_code, status_code=502)


class ServiceException(AppException):
    """Business logic layer error (500)."""
    
    def __init__(self, message: str, error_code: str = "SERVICE_ERROR"):
        super().__init__(message, error_code=error_code, status_code=500)


class NotFoundException(AppException):
    """Resource not found (404)."""
    
    def __init__(self, message: str, error_code: str = "NOT_FOUND"):
        super().__init__(message, error_code=error_code, status_code=404)


class TranslationException(ServiceException):
    """Translation-specific service error."""
    
    def __init__(self, message: str, error_code: str = "TRANSLATION_ERROR"):
        super().__init__(message, error_code=error_code)
