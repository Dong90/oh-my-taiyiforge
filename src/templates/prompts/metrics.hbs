"""

import time
import threading
from typing import Dict, Optional
from ..core.logger import get_logger

logger = get_logger(__name__)


class MetricsService:
    """Singleton metrics service for application observability.
    
    Thread-safe counters for requests, errors, and response times.
    """
    
    _instance: Optional["MetricsService"] = None
    _lock = threading.Lock()
    
    def __new__(cls):
        if cls._instance is None:
            with cls._lock:
                if cls._instance is None:
                    cls._instance = super().__new__(cls)
                    cls._instance._init()
        return cls._instance
    
    def _init(self):
        """Initialize counters (called once on first instantiation)."""
        self._start_time = time.time()
        self._lock = threading.Lock()
        self._total_requests: Dict[str, int] = {}
        self._total_errors: Dict[str, int] = {}
        self._response_times: Dict[str, list] = {}
        self._active_requests = 0
    
    def record_request(self, endpoint: str, response_time_ms: float, success: bool = True):
        """Record a completed request."""
        with self._lock:
            self._total_requests[endpoint] = self._total_requests.get(endpoint, 0) + 1
            if endpoint not in self._response_times:
                self._response_times[endpoint] = []
            self._response_times[endpoint].append(response_time_ms)
            if not success:
                self._total_errors[endpoint] = self._total_errors.get(endpoint, 0) + 1
    
    def record_error(self, endpoint: str, error_type: str):
        """Record an error type for an endpoint."""
        with self._lock:
            key = f"{endpoint}:{error_type}"
            self._total_errors[key] = self._total_errors.get(key, 0) + 1
    
    def get_metrics(self) -> dict:
        """Get current metrics snapshot."""
        with self._lock:
            total_requests = sum(self._total_requests.values())
            total_errors = sum(v for k, v in self._total_errors.items() if ":" not in k)
            error_rate = (total_errors / total_requests * 100) if total_requests > 0 else 0
            
            avg_times = {}
            for endpoint, times in self._response_times.items():
                if times:
                    sorted_times = sorted(times)
                    avg_times[endpoint] = {
                        "avg_ms": round(sum(times) / len(times), 2),
                        "p50_ms": sorted_times[len(times) // 2],
                        "p95_ms": sorted_times[int(len(times) * 0.95)],
                        "p99_ms": sorted_times[int(len(times) * 0.99)],
                        "count": len(times),
                    }
            
            return {
                "uptime_seconds": round(time.time() - self._start_time, 2),
                "total_requests": total_requests,
                "total_errors": total_errors,
                "error_rate_percent": round(error_rate, 2),
                "endpoints": {
                    ep: {
                        "requests": self._total_requests.get(ep, 0),
                        "errors": self._total_errors.get(ep, 0),
                        "avg_ms": avg_times.get(ep, {}).get("avg_ms", 0),
                        "p95_ms": avg_times.get(ep, {}).get("p95_ms", 0),
                    }
                    for ep in self._total_requests
                },
            }
    
    def reset(self):
        """Reset all counters (for testing)."""
        self._init()


def get_metrics_service() -> MetricsService:
    """Get the singleton metrics service instance."""
    return MetricsService()
